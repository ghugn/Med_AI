# ---------------------------------------------------------------------------
# MedPilot Frontend — Environment Variables
# Copy this file to .env.local and fill in real values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# ---------------------------------------------------------------------------

# Backend / AI service base URL (used by next.config rewrites at build time)
BACKEND_URL=http://localhost:8000

# Optionally expose the base URL to client components (e.g. for WebSocket)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Auth secret for NextAuth / JWT signing (generate with: openssl rand -hex 32)
NEXTAUTH_SECRET=change_me_in_production
NEXTAUTH_URL=http://localhost:3000

# Feature flags
NEXT_PUBLIC_ENABLE_IMAGE_UPLOAD=false
NEXT_PUBLIC_MOCK_API=true
