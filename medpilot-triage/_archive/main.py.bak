import os
import time
import asyncio
import uuid
from datetime import datetime
from typing import List, Optional, Any, Dict
import pandas as pd
from fastapi import FastAPI, HTTPException
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel, Field

# Khai báo cấu hình file Database và cấu trúc Headers
DB_FILE = "database.xlsx"

HEADERS = [
    "Case_ID", "Ngày_giờ_khám", "Bác_sĩ_ID", "Họ_tên_BN", "Tuổi", "Giới_tính",
    "Triệu_chứng_Transcript", 
    "Extracted_Entities",
    "Chẩn_đoán_sơ_bộ", "Hướng_giải_quyết", "Draft_Note", "Problem_List",
    "Missing_Info", "Red_Flag", "Uncertainty_Score", "Safety_Status",
    "SpO2_Final", "HR_Final", "BP_Final"
]

app = FastAPI(
    title="MedPilot API (Demo POC)",
    description="Backend trung chuyển cho trợ lý AI y khoa MedPilot. Tích hợp Safety Layer & Logging."
)

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# -----------------------------------------------------
# 1. THIẾT LẬP DATABASE BẰNG EXCEL
# -----------------------------------------------------

def init_db() -> None:
    """ Khởi tạo database.xlsx nếu chưa tồn tại """
    if not os.path.exists(DB_FILE):
        print(f"[*] Đang khởi tạo file giả lập: {DB_FILE}...")
        df = pd.DataFrame(columns=HEADERS)
        df.to_excel(DB_FILE, index=False, engine='openpyxl')
        print(f"[+] Đã tạo file {DB_FILE} thành công")
    else:
        print(f"[i] File {DB_FILE} đã tồn tại. Sẵn sàng sử dụng!")

def save_to_excel(data_dict: dict) -> None:
    """ Thêm mới một dòng (ca bệnh) vào database.xlsx """
    try:
        processed = data_dict.copy()
        for k, v in processed.items():
            if isinstance(v, list) or isinstance(v, dict):
                processed[k] = str(v)
                
        if os.path.exists(DB_FILE):
            df_existing = pd.read_excel(DB_FILE, engine='openpyxl')
        else:
            df_existing = pd.DataFrame(columns=HEADERS)
            
        df_new = pd.DataFrame([processed])
        df_combined = pd.concat([df_existing, df_new], ignore_index=True)
        df_combined.to_excel(DB_FILE, index=False, engine='openpyxl')
    except Exception as e:
        print(f"[-] Lỗi lưu database.xlsx: {e}")

def update_excel(case_id: str, update_dict: dict) -> None:
    """ Cập nhật thông tin cho một Case_ID đã có trong database.xlsx """
    try:
        if not os.path.exists(DB_FILE):
            return
        df = pd.read_excel(DB_FILE, engine='openpyxl')
        
        # Tiền xử lý list/dict -> string
        processed = update_dict.copy()
        for k, v in processed.items():
            if isinstance(v, list) or isinstance(v, dict):
                processed[k] = str(v)
                
        # Tìm dòng có Case_ID tương ứng và cập nhật
        mask = df['Case_ID'] == case_id
        if mask.any():
            for k, v in processed.items():
                if k in df.columns:
                    df.loc[mask, k] = v
            df.to_excel(DB_FILE, index=False, engine='openpyxl')
            print(f"[+] Cập nhật DB cho Case_ID '{case_id}' thành công!")
        else:
            print(f"[-] Không tìm thấy Case_ID '{case_id}' để cập nhật vào DB.")
    except Exception as e:
        print(f"[-] Lỗi cập nhật excel: {e}")

def log_ai_interaction(case_id: str, endpoint: str, latency: float, error_msg: str, ai_output: str) -> None:
    """ (Yêu cầu 4) Nâng cấp Logging tĩnh vào db excel """
    try:
        # Ghi log dưới dạng dòng mới vào DB với Endpoint là định danh
        log_data = {
            "Case_ID": case_id,
            "Ngày_giờ_khám": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
            "Triệu_chứng_Transcript": f"[LOG] {endpoint} | Latency: {latency}s | Error: {error_msg} | Output: {ai_output}"
        }
        save_to_excel(log_data)
        print(f"[LOG] Đã ghi log API {endpoint} mất {latency}s")
    except Exception as e:
        print(f"[-] Lỗi ghi nhận log: {e}")


@app.on_event("startup")
async def startup_event():
    init_db()


# -----------------------------------------------------
# 2. ĐỊNH NGHĨA DATA SCHEMA (PYDANTIC MODELS)
# -----------------------------------------------------

class PatientInput(BaseModel):
    ho_ten: str = Field(..., description="Họ và tên bệnh nhân")
    tuoi: int = Field(..., description="Tuổi bệnh nhân")
    gioi_tinh: str = Field(..., description="Giới tính")
    bac_si_id: str = Field(..., description="ID của bác sĩ tiếp nhận")
    trieu_chung_transcript: str = Field(..., description="Đoạn text triệu chứng")

class AIOutput(BaseModel): 
    chan_doan_so_bo: str
    huong_giai_quyet: str
    missing_info: List[str]
    red_flag: str
    uncertainty_score: float

class SummarizeOutput(BaseModel):
    draft_note: str
    problem_list: List[str]
    missing_info_checklist: List[str]
    red_flag: str = Field(..., description="CAO/Trung bình/Thấp")
    uncertainty_score: float = Field(..., description="0.0 đến 1.0")

# Chuẩn format trả về Frontend
class APIResponse(BaseModel):
    status: str
    alert_level: str
    action_required: str
    message: str
    data: Optional[Any] = None

class DoctorApproveInput(BaseModel):
    draft_note: str
    spo2: Optional[str] = None
    hr: Optional[str] = None
    bp: Optional[str] = None

# -----------------------------------------------------
# 3. TẠO API ENDPOINT
# -----------------------------------------------------

@app.post("/cases/create", summary="Tạo ca bệnh mới", tags=["Cases"])
async def create_case(patient: PatientInput):
    case_id = "CASE_" + str(uuid.uuid4())[:8].upper()
    current_time = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    
    db_record = {
        "Case_ID": case_id,
        "Ngày_giờ_khám": current_time,
        "Bác_sĩ_ID": patient.bac_si_id,
        "Họ_tên_BN": patient.ho_ten,
        "Tuổi": patient.tuoi,
        "Giới_tính": patient.gioi_tinh,
        "Triệu_chứng_Transcript": patient.trieu_chung_transcript,
        "Safety_Status": "created"
    }
    
    save_to_excel(db_record)
    print(f"[INFO] Khởi tạo ca mới {case_id}")
    
    return {
        "status": "success",
        "message": "Ca bệnh đã được khởi tạo",
        "data": {
            "case_id": case_id,
            "created_at": current_time
        }
    }


@app.post("/cases/{case_id}/extract", summary="Trích xuất thực thể", response_model=APIResponse, tags=["AI Agents"])
async def extract_info(case_id: str):
    start_time = time.time()
    await asyncio.sleep(0.8)
    
    mock_extract_data = {
        "trieu_chung": ["đau ngực", "khó thở"],
        "thuoc_dang_dung": ["không rõ"],
        "sinh_hieu": []
    }
    
    update_excel(case_id, {"Extracted_Entities": str(mock_extract_data)})
    log_ai_interaction(case_id, "/cases/extract", round(time.time() - start_time, 2), "", str(mock_extract_data))
    
    return APIResponse(
        status="success",
        alert_level="NORMAL",
        action_required="NONE",
        message="Trích xuất thành công",
        data=mock_extract_data
    )


@app.post("/cases/{case_id}/summarize", summary="Tổng hợp & Rà soát y khoa", response_model=APIResponse, tags=["AI Agents"])
async def summarize_case(case_id: str):
    start_time = time.time()
    await asyncio.sleep(1)
    
    # Logic mock kiểm tra Red Flag
    mock_summary = SummarizeOutput(
        draft_note="Bệnh nhân nam có triệu chứng đau ngực và khó thở cấp tính. Cần theo dõi sát.",
        problem_list=["Đau ngực chưa rõ nguyên nhân", "Hội chứng vành cấp?"],
        missing_info_checklist=["SpO2", "Huyết áp", "Nhịp tim"],
        red_flag="CAO",
        uncertainty_score=0.9
    )
    
    status = "warning"
    alert_level = "CRITICAL"
    action_required = "require_input"
    message = "CẢNH BÁO: Phát hiện dấu hiệu nguy cơ cao nhưng thiếu sinh hiệu!"
    
    update_data = {
        "Draft_Note": mock_summary.draft_note,
        "Problem_List": mock_summary.problem_list,
        "Missing_Info": mock_summary.missing_info_checklist,
        "Red_Flag": mock_summary.red_flag,
        "Safety_Status": action_required
    }
    update_excel(case_id, update_data)
    log_ai_interaction(case_id, "/cases/summarize", round(time.time() - start_time, 2), "Missing Info", str(mock_summary.dict()))
    
    return APIResponse(
        status=status,
        alert_level=alert_level,
        action_required=action_required,
        message=message,
        data=mock_summary.dict()
    )


@app.post("/cases/{case_id}/doctor-approve", summary="Bác sĩ phê duyệt", response_model=APIResponse, tags=["Cases"])
async def doctor_approve(case_id: str, payload: DoctorApproveInput):
    start_time = time.time()
    update_data = {
        "Draft_Note": payload.draft_note,
        "Safety_Status": "approved_by_doctor",
        "SpO2_Final": payload.spo2,
        "HR_Final": payload.hr,
        "BP_Final": payload.bp
    }
    update_excel(case_id, update_data)
    log_ai_interaction(case_id, "/cases/doctor-approve", round(time.time() - start_time, 2), "None", "Approved")
    
    return APIResponse(
        status="success",
        alert_level="NORMAL",
        action_required="NONE",
        message="Đã lưu hồ sơ bệnh án thành công vào Excel",
        data={"case_id": case_id}
    )


if __name__ == "__main__":
    import uvicorn
    # Vẫn dùng reload=False để tránh reset giao diện khi lưu file
    uvicorn.run("main:app", host="0.0.0.0", port=8000, reload=False)
